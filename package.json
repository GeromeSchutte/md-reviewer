{
  "name": "planning-tool",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "preinstall": "bash scripts/preinstall",
    "postinstall": "bun packages/cli/src/index.ts setup",
    "setup": "bun packages/cli/src/index.ts setup",
    "uninstall": "bun packages/cli/src/index.ts teardown",
    "broker": "bun run packages/broker/src/index.ts",
    "cli": "bun run packages/cli/src/index.ts",
    "update": "bash scripts/update",
    "tauri:build": "bun run --filter '@plan-review/viewer' tauri build",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/broker/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p apps/viewer/tsconfig.json",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8"
  }
}
