#!/usr/bin/env bash
# Convenience wrapper. `bun install` already does the full setup via the preinstall
# (toolchain checks) and postinstall (symlinks + daemon + viewer) hooks — this script
# just runs it, plus a --links-only shortcut for re-wiring symlinks after moving the repo.
#
#   ./scripts/install                # full: deps + symlinks + daemon + viewer
#   ./scripts/install --links-only   # only (re)create the Claude Code symlinks
#
# To reverse everything, see ./scripts/uninstall (run it before deleting the repo).
set -euo pipefail

case "${1:-}" in
  -h|--help) sed -n '2,11p' "$0"; exit 0 ;;
esac

# Resolve this script's real location, following symlinks (BSD/macOS-safe).
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
repo="$(cd -P "$(dirname "$src")/.." && pwd)"

if [ "${1:-}" = "--links-only" ]; then
  exec bun "$repo/packages/cli/src/index.ts" setup --links-only
fi

cd "$repo"
exec bun install
