{
  "name": "planning-tool",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "broker": "bun run packages/broker/src/index.ts",
    "cli": "bun run packages/cli/src/index.ts",
    "tauri:build": "bun run --filter '@plan-review/viewer' tauri build",
    "typecheck": "tsc --build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8"
  }
}
